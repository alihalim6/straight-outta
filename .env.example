# Frontend (Vite). Copy to .env in repo root.
# Spotify PKCE: create an app at https://developer.spotify.com/dashboard and set Redirect URI to http://localhost:5173/callback (or your VITE_APP_URL/callback).
VITE_SPOTIFY_CLIENT_ID=
# Your HTTP API URL that invokes the playlist refresh Lambda (e.g. https://xxxxx.execute-api.region.amazonaws.com/refresh).
VITE_API_URL=
# Optional: base URL for redirect (defaults to window.location.origin).
# VITE_APP_URL=http://localhost:5173
